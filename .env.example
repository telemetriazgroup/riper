# Copiar a .env y ajustar valores.
# La API puede tener otra IP/host; configurar aquí evita CORS en desarrollo.

# URL base que usa el frontend para llamar a la API TermoKing.
# - URL completa: el navegador llama directo a esa IP (la API debe permitir CORS).
# - /api: en desarrollo Vite hace proxy a VITE_API_PROXY_TARGET (evita CORS).
VITE_API_BASE_URL=http://localhost:9055

# Solo aplica en desarrollo cuando VITE_API_BASE_URL=/api.
# URL real del backend; el proxy reenvía /api/* hacia aquí.
# Ejemplo si la API está en otra máquina: http://192.168.1.10:9055
VITE_API_PROXY_TARGET=http://localhost:9055
